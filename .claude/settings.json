{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(./mvnw:*)",
      "Bash(./build.sh:*)",
      "Bash(./build.ps1:*)",
      "Bash(docker:*)",
      "Bash(keytool:*)",
      "Read:src/**",
      "Read:docker/**",
      "Read:CLAUDE.md",
      "Read:AGENTS.md",
      "Write:src/**",
      "Write:.claude/**"
    ],
    "deny": [
      "Read:key/**",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(rm -rf:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/nohder/dev/lbb/stp-client && ./mvnw compile -q 2>&1 | tail -5",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
